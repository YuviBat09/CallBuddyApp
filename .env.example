# Twilio
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_PHONE_NUMBER=+1xxxxxxxxxx

# Anthropic
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxx

# OpenAI
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxx

# Deepgram
DEEPGRAM_API_KEY=xxxxxxxxxxxxxxxxxxxx

# Server
PORT=3000
# Public URL exposed to Twilio (ngrok URL in dev)
SERVER_URL=https://xxxx.ngrok.io

# Google Sheets latency export (optional — omit GOOGLE_SHEET_ID to disable)
# 1. Create a Google Cloud project → enable "Google Sheets API"
# 2. Create a Service Account → download JSON key → save as google-credentials.json
# 3. Share your Google Sheet with the service account email (Editor role)
# 4. Copy the sheet ID from its URL: .../spreadsheets/d/<SHEET_ID>/edit
GOOGLE_SHEET_ID=
# Path to service account key JSON (default: ./google-credentials.json)
GOOGLE_CREDENTIALS_PATH=./google-credentials.json
# OR: inline the whole JSON as a single string (useful for hosted envs)
# GOOGLE_CREDENTIALS_JSON={"type":"service_account",...}
# Sheet tab name (default: Latency)
GOOGLE_SHEET_TAB=Latency
